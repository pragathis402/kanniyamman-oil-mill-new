# ═══════════════════════════════════════════
#  Sri Kanniyamman Oil Mill — ENV Variables
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server Port
PORT=5000

# MongoDB Atlas URI
# Get from: https://cloud.mongodb.com → Connect → Drivers
# Replace <password> with your actual password
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/kanniyamman_oil?retryWrites=true&w=majority

# Gmail for sending emails
# Use your Gmail address that has 2FA enabled
EMAIL_USER=yourgmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# Select App: Mail, Device: Other → name it "Nodemailer"
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Seller notification email
SELLER_EMAIL=kanniyammanoilscompraj@gmail.com

# Frontend URL (for CORS — set to your Render frontend URL)
FRONTEND_URL=https://your-frontend.onrender.com
